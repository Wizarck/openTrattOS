# ============================================================================
# rag-proxy environment variables (production-cleared shape; m2-wrap-up)
# ============================================================================
# Deployment notes are in docs/operations/m2-prod-runbook.md.
# Copy this to .env on the VPS and fill in real values; never commit .env.

# ----------------------------------------------------------------------------
# LightRAG (existing on the VPS — do NOT modify LightRAG itself per ADR-022)
# ----------------------------------------------------------------------------
# Internal URL pointing at your existing RAGAnything+LightRAG deployment.
LIGHTRAG_BASE_URL=http://lightrag:9621

# Your LightRAG X-API-Key, if auth is enabled on that side.
LIGHTRAG_API_KEY=

# HTTP timeout for queries to LightRAG. Default 30s.
LIGHTRAG_TIMEOUT_S=30

# LightRAG retrieval mode: hybrid / local / global / mix / naive. Default hybrid.
LIGHTRAG_MODE=hybrid

# Below this hybrid score, fall through to Brave Search fallback (if enabled).
LIGHTRAG_SCORE_THRESHOLD=0.6

# ----------------------------------------------------------------------------
# Brave Search fallback (default off; opt in once corpus path is proven)
# ----------------------------------------------------------------------------
# Master switch. First production deploy keeps this `false` so the proxy uses
# the corpus path only. Flip to `true` after a week of corpus-only operation
# proves out and you've provisioned a Brave API key.
BRAVE_ENABLED=false

# Brave Search API subscription key. Required only when BRAVE_ENABLED=true.
BRAVE_API_KEY=

# Brave HTTP timeout. Default 10s.
BRAVE_TIMEOUT_S=10

# Per-UTC-day soft budget for Brave queries. The proxy short-circuits to null
# (no API call) once this is reached; counter resets at midnight UTC.
# Free Brave tier is 2000 queries/month — keeping default at 1000/day means
# you'd burn through monthly quota in 2 days IF every query missed corpus AND
# hit Brave. In practice corpus hit-rate is high; expect <100 Brave calls/day.
BRAVE_DAILY_BUDGET=1000

# Hostname whitelist (comma-separated). Subdomain-suffix matching enforced.
# Default covers the authoritative public-domain / official-source sites
# the corpus already prefers. Add `<your-trusted-hosts>` if you trust extra
# sources for your jurisdiction (per-jurisdiction nutrition agencies, etc.).
BRAVE_DOMAIN_WHITELIST=fdc.nal.usda.gov,eur-lex.europa.eu,efsa.europa.eu,fda.gov,who.int,fao.org,ciaa.es,en.wikipedia.org,es.wikipedia.org

# ----------------------------------------------------------------------------
# Bearer auth from apps/api → rag-proxy
# ----------------------------------------------------------------------------
# apps/api sends `Authorization: Bearer <key>`. This key MUST equal the value
# of `OPENTRATTOS_AI_RAG_API_KEY` in apps/api's production .env.
# Generate a strong random secret per environment; rotate periodically.
RAG_PROXY_API_KEY=replace-me-with-a-strong-secret-per-environment
