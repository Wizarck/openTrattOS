# ============================================================================
# apps/api environment variables
# ============================================================================
# This file documents the env vars consumed by the API server. Copy to .env
# and fill in real values at deploy time. Never commit .env to git.
#
# Production-cleared defaults (post m2-wrap-up, 2026-05-06):
#   - NEXANDRO_LABELS_PROD_ENABLED=true (legal review filed; ADR-019 gate cleared)
#   - NEXANDRO_AI_YIELD_SUGGESTIONS_ENABLED=true (rag-proxy deployed +
#     corpus ingested per Wave 1.8; ADR-018 gate cleared)
#
# Note: the runtime fallback in apps/api code remains `false` for both flags
# (safety default when env unset). Operators must explicitly set these in
# their production .env. See docs/operations/m2-prod-runbook.md for the full
# deploy + rollback procedure.

# ----------------------------------------------------------------------------
# Labels (Wave 1.6: m2-labels-rendering)
# ----------------------------------------------------------------------------
# Master switch for production-grade EU 1169/2011 nutritional labels. Gated
# pre-launch on external legal review per ADR-019 §Risk. As of 2026-05-06
# the legal review is filed and approved for Spain/EU jurisdiction; flag
# documented as `=true` for production.
#
# IMPORTANT: legal review covers Spain/EU only. Repeat the review before
# enabling in any other jurisdiction (see docs/operations/m2-prod-runbook.md).
NEXANDRO_LABELS_PROD_ENABLED=true

# ----------------------------------------------------------------------------
# AI yield/waste suggestion engine (Wave 1.7: m2-ai-yield-suggestions
# + Wave 1.8: m2-ai-yield-corpus)
# ----------------------------------------------------------------------------
# Master switch. When `false` (default), every /ai-suggestions endpoint
# returns 404 and the YieldEditor / WasteFactorEditor UIs hide AI affordances.
# As of 2026-05-06 the rag-proxy is deployed and the USDA + EU 1169 +
# Escoffier corpus is ingested in LightRAG; flag documented as `=true` for
# production.
NEXANDRO_AI_YIELD_SUGGESTIONS_ENABLED=true

# Base URL for the AI RAG endpoint speaking the canonical
# {value, citationUrl, snippet} contract.
#
# IMPORTANT: this should target the rag-proxy URL, NOT LightRAG directly.
# The proxy translates LightRAG's prose+references shape into the canonical
# contract (see ADR-022, ADR-024, and tools/rag-proxy/README.md).
#
# Example (production):
#   NEXANDRO_AI_RAG_BASE_URL=https://rag-proxy.nexandro.local
#
# Example (dev with rag-proxy on localhost):
#   NEXANDRO_AI_RAG_BASE_URL=http://localhost:8000
NEXANDRO_AI_RAG_BASE_URL=https://rag-proxy.nexandro.local

# Bearer token sent as `Authorization: Bearer <key>` to the rag-proxy.
# Must match `RAG_PROXY_API_KEY` configured in tools/rag-proxy/.env.
NEXANDRO_AI_RAG_API_KEY=

# HTTP timeout in milliseconds for AI provider calls. Default: 5000.
NEXANDRO_AI_RAG_TIMEOUT_MS=5000

# Model name + version recorded in `ai_suggestions.model_name` /
# `ai_suggestions.model_version` for audit trail. The actual model behind
# the rag-proxy / LightRAG is independent — these are labels for traceability.
NEXANDRO_AI_RAG_MODEL_NAME=gpt-oss-20b-rag
NEXANDRO_AI_RAG_MODEL_VERSION=1.0

# ─────────────────────────────────────────────────────────────────
# m2-mcp-write-capabilities (Wave 1.13) — per-capability kill-switches
# ─────────────────────────────────────────────────────────────────
#
# When viaAgent === true (i.e. the request arrived through the MCP
# layer and carries X-Via-Agent + X-Agent-Name headers), the API
# checks the corresponding flag below and returns HTTP 503 with
# code=AGENT_CAPABILITY_DISABLED if disabled. Direct REST/UI traffic
# IGNORES these flags (UI is not "viaAgent").
#
# Default: ALL flags are false. Operators flip what they need;
# changes apply on apps/api restart. The MCP server registers all
# capabilities unconditionally — toggling here does NOT require an
# MCP server redeploy (per ADR-MCP-W-FLAGS).
#
# WARNING: this slice runs in trusted-internal-network mode only.
# Production deployments MUST place the MCP server inside the same
# private network as apps/api. Signature verification (3c) lands in
# m2-mcp-agent-registry-bench.

# recipes.*
NEXANDRO_AGENT_RECIPES_CREATE_ENABLED=false
NEXANDRO_AGENT_RECIPES_UPDATE_ENABLED=false
NEXANDRO_AGENT_RECIPES_SET_LINE_SOURCE_ENABLED=false
NEXANDRO_AGENT_RECIPES_DELETE_ENABLED=false
NEXANDRO_AGENT_RECIPES_SET_ALLERGENS_OVERRIDE_ENABLED=false
NEXANDRO_AGENT_RECIPES_SET_DIET_FLAGS_OVERRIDE_ENABLED=false
NEXANDRO_AGENT_RECIPES_SET_CROSS_CONTAMINATION_ENABLED=false

# menu-items.*
NEXANDRO_AGENT_MENU_ITEMS_CREATE_ENABLED=false
NEXANDRO_AGENT_MENU_ITEMS_UPDATE_ENABLED=false
NEXANDRO_AGENT_MENU_ITEMS_DELETE_ENABLED=false

# ingredients.*  (note: ingredients.import not yet supported via MCP)
NEXANDRO_AGENT_INGREDIENTS_CREATE_ENABLED=false
NEXANDRO_AGENT_INGREDIENTS_UPDATE_ENABLED=false
NEXANDRO_AGENT_INGREDIENTS_DELETE_ENABLED=false
NEXANDRO_AGENT_INGREDIENTS_REACTIVATE_ENABLED=false
NEXANDRO_AGENT_INGREDIENTS_APPLY_OVERRIDE_ENABLED=false
NEXANDRO_AGENT_INGREDIENTS_IMPORT_ENABLED=false

# categories.*
NEXANDRO_AGENT_CATEGORIES_CREATE_ENABLED=false
NEXANDRO_AGENT_CATEGORIES_UPDATE_ENABLED=false
NEXANDRO_AGENT_CATEGORIES_DELETE_ENABLED=false

# suppliers.*
NEXANDRO_AGENT_SUPPLIERS_CREATE_ENABLED=false
NEXANDRO_AGENT_SUPPLIERS_UPDATE_ENABLED=false
NEXANDRO_AGENT_SUPPLIERS_DELETE_ENABLED=false

# supplier-items.*
NEXANDRO_AGENT_SUPPLIER_ITEMS_CREATE_ENABLED=false
NEXANDRO_AGENT_SUPPLIER_ITEMS_UPDATE_ENABLED=false
NEXANDRO_AGENT_SUPPLIER_ITEMS_PROMOTE_PREFERRED_ENABLED=false
NEXANDRO_AGENT_SUPPLIER_ITEMS_DELETE_ENABLED=false

# labels.*
NEXANDRO_AGENT_LABELS_PRINT_ENABLED=false
NEXANDRO_AGENT_LABELS_SET_ORG_LABEL_FIELDS_ENABLED=false

# ai-suggestions.*
NEXANDRO_AGENT_AI_SUGGESTIONS_YIELD_ENABLED=false
NEXANDRO_AGENT_AI_SUGGESTIONS_WASTE_ENABLED=false
NEXANDRO_AGENT_AI_SUGGESTIONS_ACCEPT_ENABLED=false
NEXANDRO_AGENT_AI_SUGGESTIONS_REJECT_ENABLED=false

# external-catalog.*
NEXANDRO_AGENT_EXTERNAL_CATALOG_SYNC_ENABLED=false

# iam.users.*
NEXANDRO_AGENT_IAM_USERS_CREATE_ENABLED=false
NEXANDRO_AGENT_IAM_USERS_UPDATE_ENABLED=false
NEXANDRO_AGENT_IAM_USERS_CHANGE_PASSWORD_ENABLED=false
NEXANDRO_AGENT_IAM_USERS_ADD_LOCATION_ENABLED=false
NEXANDRO_AGENT_IAM_USERS_REMOVE_LOCATION_ENABLED=false

# iam.locations.*
NEXANDRO_AGENT_IAM_LOCATIONS_CREATE_ENABLED=false
NEXANDRO_AGENT_IAM_LOCATIONS_UPDATE_ENABLED=false
NEXANDRO_AGENT_IAM_LOCATIONS_DELETE_ENABLED=false

# iam.organizations.*
NEXANDRO_AGENT_IAM_ORGANIZATIONS_CREATE_ENABLED=false
NEXANDRO_AGENT_IAM_ORGANIZATIONS_UPDATE_ENABLED=false

# ===================================================================
# Wave 1.13 [3b] — m2-mcp-agent-chat-widget (web chat surface)
# ===================================================================
# Master flag for the web chat. When `false`, POST /agent-chat/stream
# returns 404 and the apps/web widget renders nothing.
NEXANDRO_AGENT_ENABLED=false

# Hermes web_via_http_sse platform endpoint. Ships on 127.0.0.1:8644 in
# the eligia-vps overlay; override per deployment.
NEXANDRO_HERMES_BASE_URL=http://127.0.0.1:8644

# Shared secret with Hermes' WEB_VIA_HTTP_SSE_AUTH_SECRET. Generate with
# `openssl rand -hex 32`. Rotation: update on both ends in lockstep,
# then restart both containers.
NEXANDRO_HERMES_AUTH_SECRET=

# ===================================================================
# Wave 1.13 [3c] — m2-mcp-agent-registry-bench (signing + bench)
# ===================================================================
# Per-agent Ed25519 signature enforcement. Default OFF to preserve the
# 3a + 3b unsigned trusted-internal-network path during day-1 rollout.
#
# Three forms accepted:
#   false / unset / 0        → no enforcement (legacy path)
#   true / 1 / yes           → enforce for ALL orgs
#   <uuid>,<uuid>,...        → enforce only for the listed orgs
#                              (per-org staged rollout)
#
# Day-N rollout: register each org's agents via POST /agent-credentials,
# then add that org id to this list and restart apps/api. Rollback by
# removing the org id from the list.
#
# IMPORTANT: forgetting to flip this on is a security gap. The runbook
# `docs/operations/m2-mcp-agent-registry-bench-runbook.md` documents the
# rollout checklist + an audit query that flags drift.
NEXANDRO_AGENT_SIGNATURE_REQUIRED=false

# ===================================================================
# Wave 2.1 — m3-email-dispatch-di (slice #22, ADR-039 + ADR-EMAIL-*)
# ===================================================================
# Provider-agnostic email dispatch: SMTP (AGPL default), SendGrid
# (Enterprise bundled), Postmark (alternative Enterprise, lazy-imported).
# Consumed by recall dossier dispatch (slice #13), APPCC export delivery
# (#15), and AI budget tier alerts (#19).
#
# Selection: process-global, read once at module init. Per-org override
# deferred to `m3-email-per-org-provider` followup.
#
# Allowed values: smtp | sendgrid | postmark
NEXANDRO_EMAIL_PROVIDER=smtp

# Canonical sender address. Provider-specific verification (e.g. SendGrid
# sender authentication, Postmark verified sender signature) is the
# operator's responsibility — see docs/operations/email-deliverability.md
# (shipped in slice followup).
NEXANDRO_EMAIL_FROM=notifications@your-tenant.example

# --- SMTP-specific (used when NEXANDRO_EMAIL_PROVIDER=smtp) ---
# Host + port for the SMTP relay. Defaults target a local mailpit dev
# container; replace with the production relay in staging/prod.
NEXANDRO_SMTP_HOST=localhost
NEXANDRO_SMTP_PORT=587
# Optional auth — leave blank to send without SMTP authentication
# (mailpit dev / open relay scenarios).
NEXANDRO_SMTP_USER=
NEXANDRO_SMTP_PASS=
# Connection pool size for nodemailer. Default 5 — tune up for budget-
# alert bursts (slice #19) if pool-exhaustion warnings appear.
NEXANDRO_SMTP_POOL_SIZE=5

# --- SendGrid-specific (used when NEXANDRO_EMAIL_PROVIDER=sendgrid) ---
NEXANDRO_SENDGRID_API_KEY=

# --- Postmark-specific (used when NEXANDRO_EMAIL_PROVIDER=postmark) ---
# Postmark Server Token (NOT the account token). Generated per Postmark
# server in the Postmark dashboard.
NEXANDRO_POSTMARK_SERVER_TOKEN=
