# ============================================================================
# apps/api environment variables
# ============================================================================
# This file documents the env vars consumed by the API server. Copy to .env
# and fill in real values at deploy time. Never commit .env to git.
#
# Production-cleared defaults (post m2-wrap-up, 2026-05-06):
#   - OPENTRATTOS_LABELS_PROD_ENABLED=true (legal review filed; ADR-019 gate cleared)
#   - OPENTRATTOS_AI_YIELD_SUGGESTIONS_ENABLED=true (rag-proxy deployed +
#     corpus ingested per Wave 1.8; ADR-018 gate cleared)
#
# Note: the runtime fallback in apps/api code remains `false` for both flags
# (safety default when env unset). Operators must explicitly set these in
# their production .env. See docs/operations/m2-prod-runbook.md for the full
# deploy + rollback procedure.

# ----------------------------------------------------------------------------
# Labels (Wave 1.6: m2-labels-rendering)
# ----------------------------------------------------------------------------
# Master switch for production-grade EU 1169/2011 nutritional labels. Gated
# pre-launch on external legal review per ADR-019 §Risk. As of 2026-05-06
# the legal review is filed and approved for Spain/EU jurisdiction; flag
# documented as `=true` for production.
#
# IMPORTANT: legal review covers Spain/EU only. Repeat the review before
# enabling in any other jurisdiction (see docs/operations/m2-prod-runbook.md).
OPENTRATTOS_LABELS_PROD_ENABLED=true

# ----------------------------------------------------------------------------
# AI yield/waste suggestion engine (Wave 1.7: m2-ai-yield-suggestions
# + Wave 1.8: m2-ai-yield-corpus)
# ----------------------------------------------------------------------------
# Master switch. When `false` (default), every /ai-suggestions endpoint
# returns 404 and the YieldEditor / WasteFactorEditor UIs hide AI affordances.
# As of 2026-05-06 the rag-proxy is deployed and the USDA + EU 1169 +
# Escoffier corpus is ingested in LightRAG; flag documented as `=true` for
# production.
OPENTRATTOS_AI_YIELD_SUGGESTIONS_ENABLED=true

# Base URL for the AI RAG endpoint speaking the canonical
# {value, citationUrl, snippet} contract.
#
# IMPORTANT: this should target the rag-proxy URL, NOT LightRAG directly.
# The proxy translates LightRAG's prose+references shape into the canonical
# contract (see ADR-022, ADR-024, and tools/rag-proxy/README.md).
#
# Example (production):
#   OPENTRATTOS_AI_RAG_BASE_URL=https://rag-proxy.opentrattos.local
#
# Example (dev with rag-proxy on localhost):
#   OPENTRATTOS_AI_RAG_BASE_URL=http://localhost:8000
OPENTRATTOS_AI_RAG_BASE_URL=https://rag-proxy.opentrattos.local

# Bearer token sent as `Authorization: Bearer <key>` to the rag-proxy.
# Must match `RAG_PROXY_API_KEY` configured in tools/rag-proxy/.env.
OPENTRATTOS_AI_RAG_API_KEY=

# HTTP timeout in milliseconds for AI provider calls. Default: 5000.
OPENTRATTOS_AI_RAG_TIMEOUT_MS=5000

# Model name + version recorded in `ai_suggestions.model_name` /
# `ai_suggestions.model_version` for audit trail. The actual model behind
# the rag-proxy / LightRAG is independent — these are labels for traceability.
OPENTRATTOS_AI_RAG_MODEL_NAME=gpt-oss-20b-rag
OPENTRATTOS_AI_RAG_MODEL_VERSION=1.0

# ─────────────────────────────────────────────────────────────────
# m2-mcp-write-capabilities (Wave 1.13) — per-capability kill-switches
# ─────────────────────────────────────────────────────────────────
#
# When viaAgent === true (i.e. the request arrived through the MCP
# layer and carries X-Via-Agent + X-Agent-Name headers), the API
# checks the corresponding flag below and returns HTTP 503 with
# code=AGENT_CAPABILITY_DISABLED if disabled. Direct REST/UI traffic
# IGNORES these flags (UI is not "viaAgent").
#
# Default: ALL flags are false. Operators flip what they need;
# changes apply on apps/api restart. The MCP server registers all
# capabilities unconditionally — toggling here does NOT require an
# MCP server redeploy (per ADR-MCP-W-FLAGS).
#
# WARNING: this slice runs in trusted-internal-network mode only.
# Production deployments MUST place the MCP server inside the same
# private network as apps/api. Signature verification (3c) lands in
# m2-mcp-agent-registry-bench.

# recipes.*
OPENTRATTOS_AGENT_RECIPES_CREATE_ENABLED=false
OPENTRATTOS_AGENT_RECIPES_UPDATE_ENABLED=false
OPENTRATTOS_AGENT_RECIPES_SET_LINE_SOURCE_ENABLED=false
OPENTRATTOS_AGENT_RECIPES_DELETE_ENABLED=false
OPENTRATTOS_AGENT_RECIPES_SET_ALLERGENS_OVERRIDE_ENABLED=false
OPENTRATTOS_AGENT_RECIPES_SET_DIET_FLAGS_OVERRIDE_ENABLED=false
OPENTRATTOS_AGENT_RECIPES_SET_CROSS_CONTAMINATION_ENABLED=false

# menu-items.*
OPENTRATTOS_AGENT_MENU_ITEMS_CREATE_ENABLED=false
OPENTRATTOS_AGENT_MENU_ITEMS_UPDATE_ENABLED=false
OPENTRATTOS_AGENT_MENU_ITEMS_DELETE_ENABLED=false

# ingredients.*  (note: ingredients.import not yet supported via MCP)
OPENTRATTOS_AGENT_INGREDIENTS_CREATE_ENABLED=false
OPENTRATTOS_AGENT_INGREDIENTS_UPDATE_ENABLED=false
OPENTRATTOS_AGENT_INGREDIENTS_DELETE_ENABLED=false
OPENTRATTOS_AGENT_INGREDIENTS_REACTIVATE_ENABLED=false
OPENTRATTOS_AGENT_INGREDIENTS_APPLY_OVERRIDE_ENABLED=false
OPENTRATTOS_AGENT_INGREDIENTS_IMPORT_ENABLED=false

# categories.*
OPENTRATTOS_AGENT_CATEGORIES_CREATE_ENABLED=false
OPENTRATTOS_AGENT_CATEGORIES_UPDATE_ENABLED=false
OPENTRATTOS_AGENT_CATEGORIES_DELETE_ENABLED=false

# suppliers.*
OPENTRATTOS_AGENT_SUPPLIERS_CREATE_ENABLED=false
OPENTRATTOS_AGENT_SUPPLIERS_UPDATE_ENABLED=false
OPENTRATTOS_AGENT_SUPPLIERS_DELETE_ENABLED=false

# supplier-items.*
OPENTRATTOS_AGENT_SUPPLIER_ITEMS_CREATE_ENABLED=false
OPENTRATTOS_AGENT_SUPPLIER_ITEMS_UPDATE_ENABLED=false
OPENTRATTOS_AGENT_SUPPLIER_ITEMS_PROMOTE_PREFERRED_ENABLED=false
OPENTRATTOS_AGENT_SUPPLIER_ITEMS_DELETE_ENABLED=false

# labels.*
OPENTRATTOS_AGENT_LABELS_PRINT_ENABLED=false
OPENTRATTOS_AGENT_LABELS_SET_ORG_LABEL_FIELDS_ENABLED=false

# ai-suggestions.*
OPENTRATTOS_AGENT_AI_SUGGESTIONS_YIELD_ENABLED=false
OPENTRATTOS_AGENT_AI_SUGGESTIONS_WASTE_ENABLED=false
OPENTRATTOS_AGENT_AI_SUGGESTIONS_ACCEPT_ENABLED=false
OPENTRATTOS_AGENT_AI_SUGGESTIONS_REJECT_ENABLED=false

# external-catalog.*
OPENTRATTOS_AGENT_EXTERNAL_CATALOG_SYNC_ENABLED=false

# iam.users.*
OPENTRATTOS_AGENT_IAM_USERS_CREATE_ENABLED=false
OPENTRATTOS_AGENT_IAM_USERS_UPDATE_ENABLED=false
OPENTRATTOS_AGENT_IAM_USERS_CHANGE_PASSWORD_ENABLED=false
OPENTRATTOS_AGENT_IAM_USERS_ADD_LOCATION_ENABLED=false
OPENTRATTOS_AGENT_IAM_USERS_REMOVE_LOCATION_ENABLED=false

# iam.locations.*
OPENTRATTOS_AGENT_IAM_LOCATIONS_CREATE_ENABLED=false
OPENTRATTOS_AGENT_IAM_LOCATIONS_UPDATE_ENABLED=false
OPENTRATTOS_AGENT_IAM_LOCATIONS_DELETE_ENABLED=false

# iam.organizations.*
