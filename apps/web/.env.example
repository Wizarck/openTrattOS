# Backend API base URL. Vite proxies /api/* to this in dev (see vite.config.ts).
# Override per environment.
VITE_API_URL=http://localhost:3000

# Demo organisation id for the J3 proof-of-concept screen. Replace with a
# real org id from your local DB seed.
VITE_DEMO_ORG_ID=11111111-1111-4111-8111-111111111111

# Wave 1.15 — m2-labels-print-config-ui. Demo-time role for the apps/web
# nav + role-aware screens (Owner-only sections like /owner-settings).
# Accepts: OWNER | MANAGER | STAFF (anything else is treated as no user).
# In production this is read from the JWT subject's `role` claim once auth
# lands (M3); the env var is dev/demo only.
VITE_DEMO_USER_ROLE=OWNER

# Wave 1.13 [3b] — m2-mcp-agent-chat-widget. When `true`, the
# AgentChatWidget mounts at the layout level (FAB + sidesheet). When
# unset / `false`, the widget renders nothing (no FAB, no listener).
# Both ends of the chat must be enabled for the feature to work:
#   - apps/api: OPENTRATTOS_AGENT_ENABLED=true
#   - apps/web: VITE_OPENTRATTOS_AGENT_ENABLED=true
# Production rollout flips both in lockstep; rollback flips them off.
VITE_OPENTRATTOS_AGENT_ENABLED=false
