{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "rootDir": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "isolatedModules": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*", "test/**/*"]
}
