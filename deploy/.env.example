# openTrattOS — operator env contract for deploy/docker-compose.prod.yml
# m3.x-app-bootstrap-and-vps-deploy slice §3.4.
#
# This file is shipped in the repo as `.env.example`. On the VPS, copy it
# to `/opt/opentrattos/.env` and fill the values:
#
#   ssh root@vps 'mkdir -p /opt/opentrattos'
#   scp deploy/.env.example root@vps:/opt/opentrattos/.env
#   ssh root@vps "cd /opt/opentrattos && nano .env"
#
# `.env` MUST NOT be committed (it carries the Postgres password).

# Postgres
POSTGRES_USER=opentrattos
POSTGRES_DB=opentrattos
# Generate via: pwgen 32 1
POSTGRES_PASSWORD=GENERATE-WITH-PWGEN-32-1

# Public hostname (Cloudflare DNS CNAME → tunnel)
FRONTEND_URL=https://trattos.palafitofood.com

# Defaults below match docker-compose.prod.yml — uncomment + change to
# enable a specific feature once its creds are provisioned.
# OTEL_SDK_DISABLED=false
# OPENTRATTOS_EMAIL_PROVIDER=smtp     # or sendgrid / postmark
# AUDIT_ARCHIVAL_ENABLED=true         # then provide AWS_S3_* envs
# PHOTO_STORAGE_ENABLED=true          # then provide AWS_S3_* envs
# M3_PO_AGGREGATE_ENABLED=true
# OPENTRATTOS_AGENT_ENABLED=true      # then provide HERMES_* envs
