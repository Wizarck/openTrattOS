{
  "name": "opentrattos",
  "version": "0.1.0",
  "private": true,
  "description": "The Open Source Back-of-House (BOH) & Kitchen Traceability OS",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wizarck/openTrattOS.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "npm run migrate --workspace=apps/api",
    "db:seed": "npm run seed --workspace=apps/api"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}
