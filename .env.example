# nexandro — community quickstart env contract
# m3.x-app-bootstrap-and-vps-deploy slice §3.2.
#
# Copy this file to `.env` and edit POSTGRES_PASSWORD before
# `docker compose up`. All other defaults work out of the box for a
# laptop / single-VPS demo.

# Postgres credentials (consumed by both the db service and the app's DATABASE_URL).
POSTGRES_USER=nexandro
POSTGRES_DB=nexandro
POSTGRES_PASSWORD=changeme-please

# CORS allowlist for the frontend. Use https:// in real deployments.
FRONTEND_URL=http://localhost:3000

# Email dispatch — leave as `smtp` (default) and provide NEXANDRO_SMTP_*
# env vars when you need real mail. The `verifyConnection()` probe on boot
# logs but does not block, so you can defer email config until needed.
# NEXANDRO_EMAIL_PROVIDER=smtp
# NEXANDRO_SMTP_HOST=
# NEXANDRO_SMTP_PORT=587
# NEXANDRO_SMTP_USER=
# NEXANDRO_SMTP_PASS=
# NEXANDRO_SMTP_FROM=

# Optional: enable feature flags only when you have the matching creds.
# AUDIT_ARCHIVAL_ENABLED=true   # requires S3-compat creds
# PHOTO_STORAGE_ENABLED=true    # requires S3-compat creds
# M3_PO_AGGREGATE_ENABLED=true  # PO/GR state-transition flow
# NEXANDRO_AGENT_ENABLED=true # AgentChat SSE (Hermes consumer)

# Sprint 4 W2-1a — m4-byo-llm-provider-key.
# 32-byte hex key for AES-256-GCM encryption of stored LLM provider API keys.
# REQUIRED for the API to boot once LlmCredentialsModule is enabled.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LLM_CREDENTIALS_ENCRYPTION_KEY=

# Sprint 4 W4 — WhatsApp ingest (skeleton). Leave empty unless the
# operator has completed the Meta Business API setup documented in
# docs/sprint4-j5-whatsapp-assessment.md §3. See apps/api/.env.example
# for the full set + comments.
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_WEBHOOK_SECRET=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_DEFAULT_ORGANIZATION_ID=
